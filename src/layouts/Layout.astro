---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <div class="stars"></div>
    <div class="twinkling"></div>
    <div class="grid-overlay"></div>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg-color: #050505;
    --primary-color: #00ffcc;
    --secondary-color: #ff0055;
    --text-main: #e0e0e0;
    --text-muted: #888;
    --glass-bg: rgba(10, 20, 30, 0.7);
    --glass-border: rgba(0, 255, 204, 0.2);
    --font-heading: 'Orbitron', sans-serif;
    --font-body: 'Rajdhani', sans-serif;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    background-color: var(--bg-color);
    color: var(--text-main);
    font-family: var(--font-body);
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  /* Animated background */
  @keyframes move-twink-back {
      from {background-position:0 0;}
      to {background-position:-10000px 5000px;}
  }

  .grid-overlay {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: 
      linear-gradient(var(--glass-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--glass-border) 1px, transparent 1px);
    background-size: 50px 50px;
    z-index: -1;
    perspective: 500px;
    transform: rotateX(60deg) scale(2.5) translateY(-100px);
    transform-origin: top center;
    opacity: 0.3;
    animation: grid-scroll 20s linear infinite;
  }

  @keyframes grid-scroll {
    0% { transform: rotateX(60deg) scale(2.5) translateY(0); }
    100% { transform: rotateX(60deg) scale(2.5) translateY(50px); }
  }

  /* Core Layout */
  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
    position: relative;
    z-index: 10;
    width: 100%;
  }

  /* Typography */
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .glitch-title {
    font-size: 3rem;
    color: var(--primary-color);
    position: relative;
    display: inline-block;
    text-shadow: 0 0 10px rgba(0,255,204,0.5);
    margin-bottom: 0.5rem;
  }
  

  /* Table Design */
  .hero {
    text-align: center;
    margin-bottom: 3rem;
    margin-top: 2rem;
  }

  .subtitle {
    font-size: 1.2rem;
    color: var(--text-muted);
    font-family: var(--font-heading);
    letter-spacing: 4px;
  }

  .leaderboard {
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    backdrop-filter: blur(10px);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 0 30px rgba(0, 255, 204, 0.1);
  }

  .table-header {
    display: flex;
    background: rgba(0, 255, 204, 0.1);
    border-bottom: 1px solid var(--glass-border);
    padding: 1rem;
    font-family: var(--font-heading);
    color: var(--primary-color);
    font-weight: bold;
    text-transform: uppercase;
  }

  .table-row {
    display: flex;
    padding: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
    animation: fade-in-up 0.5s ease-out forwards;
    opacity: 0;
    transform: translateY(20px);
    align-items: center;
  }

  .table-row:hover {
    background: rgba(0, 255, 204, 0.05);
    transform: scale(1.01);
    box-shadow: inset 4px 0 0 var(--primary-color);
  }

  .col {
    flex: 1;
    font-size: 1.2rem;
  }

  .col.index { flex: 0.5; color: var(--text-muted); }
  .col.name { flex: 2; font-weight: 600; color: #fff; }
  .col.phase { flex: 1; color: var(--secondary-color); font-weight: bold; font-family: var(--font-heading); }
  .col.date { flex: 1; color: var(--text-muted); font-size: 1rem; }
  .col.actions { flex: 0.5; text-align: right; }

  @keyframes fade-in-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .loading, .error, .empty {
    padding: 3rem;
    text-align: center;
    color: var(--primary-color);
    font-family: var(--font-heading);
    animation: pulse 1.5s infinite;
  }

  .error { color: var(--secondary-color); }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  /* Form and Input Elements */
  input, button {
    font-family: var(--font-body);
    background: rgba(0,0,0,0.5);
    border: 1px solid var(--glass-border);
    color: var(--text-main);
    padding: 0.8rem 1.2rem;
    border-radius: 4px;
    font-size: 1.1rem;
    transition: all 0.3s ease;
  }
  
  input:focus {
    outline: none;
    border-color: var(--primary-color);
    box-shadow: 0 0 10px rgba(0,255,204,0.3);
  }

  button {
    background: rgba(0, 255, 204, 0.1);
    color: var(--primary-color);
    cursor: pointer;
    font-family: var(--font-heading);
    text-transform: uppercase;
    letter-spacing: 1px;
    border: 1px solid var(--primary-color);
  }

  button:hover {
    background: var(--primary-color);
    color: #000;
    box-shadow: 0 0 15px var(--primary-color);
  }

  .btn-danger {
    background: rgba(255, 0, 85, 0.1);
    color: var(--secondary-color);
    border-color: var(--secondary-color);
    font-size: 0.9rem;
    padding: 0.4rem 0.8rem;
  }

  .btn-danger:hover {
    background: var(--secondary-color);
    color: #fff;
    box-shadow: 0 0 15px var(--secondary-color);
  }
  
  nav {
      margin-top: 2rem;
      text-align: center;
  }
  nav a {
      color: var(--primary-color);
      text-decoration: none;
      font-family: var(--font-heading);
      letter-spacing: 2px;
  }
  nav a:hover {
      text-shadow: 0 0 8px var(--primary-color);
  }
</style>
