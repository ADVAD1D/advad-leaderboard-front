---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Advad Protocol | Global Leaderboard">
  <main class="container">
    <header class="hero">
      <h1 class="glitch-title" data-text="ADVAD PROTOCOL">ADVAD PROTOCOL</h1>
      <p class="subtitle">GLOBAL LEADERBOARD</p>
    </header>

    <section class="leaderboard">
      <div class="table-header">
        <div class="col index">RANK</div>
        <div class="col name">SOLDIER</div>
        <div class="col phase">MAX PHASE</div>
        <div class="col date">LOG DATE</div>
      </div>
      <div id="leaderboard-body" class="table-body">
         <div class="loading">Loading data from command center...</div>
      </div>
    </section>

  </main>
</Layout>

<script>
  async function fetchLeaderboard() {
    try {
      const response = await fetch(`${import.meta.env.PUBLIC_API_URL}/top-pilots`);
      if (!response.ok) throw new Error("Failed to fetch data");
      
      const data = await response.json();
      const body = document.getElementById('leaderboard-body')!;
      
      if (data.length === 0) {
        body.innerHTML = '<div class="empty">No records found. The arena awaits.</div>';
        return;
      }

      body.innerHTML = '';
      data.forEach((entry: any, idx: number) => {
        const row = document.createElement('div');
        row.className = 'table-row';
        row.style.animationDelay = `${idx * 0.05}s`;
        
        row.innerHTML = `
          <div class="col index">${(idx + 1).toString().padStart(2, '0')}</div>
          <div class="col name">${entry.pilot}</div>
          <div class="col phase">${entry.phase}</div>
          <div class="col date">${entry.timestamp ? new Date(entry.timestamp).toLocaleDateString() : 'CLASSIFIED'}</div>
        `;
        body.appendChild(row);
      });
      
    } catch (e) {
        const body = document.getElementById('leaderboard-body')!;
        body.innerHTML = '<div class="error">Failed to establish connection with Command Center.</div>';
    }
  }

  fetchLeaderboard();
</script>
